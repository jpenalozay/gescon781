                                 baseTableName="rel_programacion__horario_catalogo"
                                 constraintName="fk_rel_programacion__horario_catalogo__programacion_id"
                                 referencedColumnNames="id"
                                 referencedTableName="programacion"/>

        <addForeignKeyConstraint baseColumnNames="horario_catalogo_id"
                                 baseTableName="rel_programacion__horario_catalogo"
                                 constraintName="fk_rel_programacion__horario_catalogo__horario_catalogo_id"
                                 referencedColumnNames="id"
                                 referencedTableName="horario_catalogo"/>

        <addForeignKeyConstraint baseColumnNames="profesor_id"
                                 baseTableName="programacion"
                                 constraintName="fk_programacion__profesor_id"
                                 referencedColumnNames="id"
                                 referencedTableName="profesor"/>

        <addForeignKeyConstraint baseColumnNames="automovil_id"
                                 baseTableName="programacion"
                                 constraintName="fk_programacion__automovil_id"
                                 referencedColumnNames="id"
                                 referencedTableName="automovil"/>
    </changeSet>
</databaseChangeLog>
