<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <!--
        Added the constraints for entity Programacion.
    -->
    <changeSet id="20221124030943-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="programacion_id"
                                 baseTableName="rel_programacion__dia"
                                 constraintName="fk_rel_programacion__dia__programacion_id"
                                 referencedColumnNames="id"
                                 referencedTableName="programacion"/>

        <addForeignKeyConstraint baseColumnNames="dia_id"
                                 baseTableName="rel_programacion__dia"
                                 constraintName="fk_rel_programacion__dia__dia_id"
                                 referencedColumnNames="id"
