<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <!--
        Added the constraints for entity Alumno.
    -->
    <changeSet id="20221124030930-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="persona_id"
                                 baseTableName="alumno"
                                 constraintName="fk_alumno__persona_id"
                                 referencedColumnNames="id"
                                 referencedTableName="persona"/>

        <addForeignKeyConstraint baseColumnNames="alumno_clases_id"
                                 baseTableName="alumno"
                                 constraintName="fk_alumno__alumno_clases_id"
                                 referencedColumnNames="id"
                                 referencedTableName="alumno_clases"/>
    </changeSet>
</databaseChangeLog>
