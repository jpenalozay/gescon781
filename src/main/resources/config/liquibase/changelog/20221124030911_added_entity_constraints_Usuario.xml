<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <!--
        Added the constraints for entity Usuario.
    -->
    <changeSet id="20221124030911-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="usuario"
                                 constraintName="fk_usuario__user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="jhi_user"/>

        <addForeignKeyConstraint baseColumnNames="empleado_id"
                                 baseTableName="usuario"
                                 constraintName="fk_usuario__empleado_id"
                                 referencedColumnNames="id"
                                 referencedTableName="empleado"/>

        <addForeignKeyConstraint baseColumnNames="usuario_id"
                                 baseTableName="rel_usuario__sucursal"
                                 constraintName="fk_rel_usuario__sucursal__usuario_id"
                                 referencedColumnNames="id"
                                 referencedTableName="usuario"/>

        <addForeignKeyConstraint baseColumnNames="sucursal_id"
                                 baseTableName="rel_usuario__sucursal"
                                 constraintName="fk_rel_usuario__sucursal__sucursal_id"
                                 referencedColumnNames="id"
                                 referencedTableName="sucursal"/>

        <addForeignKeyConstraint baseColumnNames="usuario_id"
                                 baseTableName="rel_usuario__computadora"
                                 constraintName="fk_rel_usuario__computadora__usuario_id"
                                 referencedColumnNames="id"
                                 referencedTableName="usuario"/>

        <addForeignKeyConstraint baseColumnNames="computadora_id"
                                 baseTableName="rel_usuario__computadora"
                                 constraintName="fk_rel_usuario__computadora__computadora_id"
                                 referencedColumnNames="id"
                                 referencedTableName="computadora"/>
    </changeSet>
</databaseChangeLog>
